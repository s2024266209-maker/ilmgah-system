{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "A book in the library catalog",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the book" },
        "author": { "type": "string", "description": "The author of the book" },
        "isbn": { "type": "string", "description": "The ISBN of the book" },
        "category": { "type": "string", "description": "The category of the book" },
        "status": { "type": "string", "enum": ["available", "reserved", "borrowed"], "description": "The current status of the book" },
        "cover": { "type": "string", "description": "The cover image URL" },
        "description": { "type": "string", "description": "A brief description of the book" },
        "publishedYear": { "type": "number", "description": "The year the book was published" },
        "totalCopies": { "type": "number", "description": "Total number of copies in the library" },
        "availableCopies": { "type": "number", "description": "Number of copies currently available" }
      },
      "required": ["title", "author", "isbn", "category", "status"]
    },
    "User": {
      "title": "User",
      "description": "A user of the library system",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The full name of the user" },
        "email": { "type": "string", "description": "The email address of the user" },
        "role": { "type": "string", "enum": ["admin", "student"], "description": "The role of the user" },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "The status of the user" },
        "id": { "type": "string", "description": "The student or admin ID" }
      },
      "required": ["name", "email", "role", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A borrowing or return transaction",
      "type": "object",
      "properties": {
        "bookId": { "type": "string", "description": "The ID of the book" },
        "userId": { "type": "string", "description": "The ID of the user" },
        "borrowDate": { "type": "string", "format": "date-time", "description": "The date the book was borrowed" },
        "dueDate": { "type": "string", "format": "date-time", "description": "The date the book is due" },
        "returnDate": { "type": "string", "format": "date-time", "description": "The date the book was returned" },
        "status": { "type": "string", "enum": ["borrowed", "returned", "overdue"], "description": "The status of the transaction" },
        "fineAmount": { "type": "number", "description": "The fine amount for late return" }
      },
      "required": ["bookId", "userId", "borrowDate", "dueDate", "status"]
    }
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of books"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of transactions"
    }
  }
}
